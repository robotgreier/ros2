
###############################################################################
# ROS 2 / Colcon Workspace Ignore File
# Applies to repositories inside a ROS 2 workspace (src/<your_repo>)
###############################################################################

# -----------------------------------------------------------------------------
# Colcon build artifacts
# -----------------------------------------------------------------------------
build/
install/
log/
.colcon_install_layout


# -----------------------------------------------------------------------------
# ROS 2 log files
# -----------------------------------------------------------------------------
taskbot_log/


# -----------------------------------------------------------------------------
# ROS 2 package generated files
# -----------------------------------------------------------------------------
**/msg_gen/
**/srv_gen/
**/action_gen/
**/ament_cmake_core/
**/ament_cmake_environment_hooks/
**/cmake-build-*/

# -----------------------------------------------------------------------------
# Python build artifacts (if your package uses rclpy)
# -----------------------------------------------------------------------------
*.pyc
*.pyo
*.pyd
__pycache__/
*.egg-info/
.eggs/
dist/
build/  # for setuptools-based python builds

# -----------------------------------------------------------------------------
# CMake / build system artifacts
# -----------------------------------------------------------------------------
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
*.cmake
*.ninja
*.ninja_deps
*.ninja_log

# -----------------------------------------------------------------------------
# VSCode and IDE clutter
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# -----------------------------------------------------------------------------
# OS / file system clutter
# -----------------------------------------------------------------------------
*.DS_Store
Thumbs.db